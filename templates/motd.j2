{% set os_name = ansible_distribution ~ ' ' ~ ansible_distribution_version %}
{% set up_secs = ansible_facts.uptime_seconds | default(ansible_uptime_seconds) | default(0) | int %}
{% set uptime = (up_secs // 86400) ~ 'd ' ~ ((up_secs % 86400) // 3600) ~ 'h' %}
{% set primary_ip = ansible_default_ipv4.address | default(ansible_all_ipv4_addresses | first | default('N/A')) %}
{% set fqdn = general_hostname | default(ansible_hostname) %}

───────────────────────────────────────────────
 🖥️   Hostname    : {{ fqdn }}
 🌍  Environment : {{ general_environment | upper }}
 🧩  OS          : {{ os_name }} ({{ ansible_architecture }})
 ⏱️   Uptime      : {{ uptime }}
 🔌  IP Address  : {{ primary_ip }}
 🧱  Managed by  : {{ general_motd_managed_by }}
───────────────────────────────────────────────
