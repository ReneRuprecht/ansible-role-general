# Managed by Ansible - do not edit manually
[Match]
Name={{ item.interface }}

[Network]
Address={{ item.ip_address }}/{{ item.ip_cidr | default(24) }}
{% for server in general_dns_servers %}
DNS={{ server }}
{% endfor %}
LinkLocalAddressing=no

{% if item.ip_gateway is defined and item.ip_gateway | string | length > 0 %}
[Route]
Gateway={{ item.ip_gateway }}
{% endif %}
